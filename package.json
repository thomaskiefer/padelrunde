{
  "name": "padelrunde",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "env:pull": "bunx convex env list > .env.convex",
    "env:push": "bunx convex env set --from-file .env.convex",
    "dev": "bunx convex dev --once && concurrently -r \"bun run dev:web\" \"bun run dev:convex\"",
    "dev:web": "vite dev",
    "dev:ts": "tsc -b -w",
    "dev:convex": "bunx convex dev",
    "build": "vite build && tsc --noEmit",
    "start": "bun .output/server/index.mjs",
    "format": "prettier --write .",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@clerk/backend": "^3.0.1",
    "@clerk/tanstack-react-start": "^1.0.1",
    "@convex-dev/react-query": "^0.1.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.158.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "lucide-react": "^0.577.0",
    "nitro": "^3.0.1-alpha.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "svix": "^1.86.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/eslint-config": "^0.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "~9.2.1",
    "convex-test": "^0.0.41",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5"
  }
}
